PI=PI = {\n  width: number?,\n  height: number?,\n  screen_size: boolean|number|nil,\n  limit_tiles: string?,\n  col: table|number|nil,\n  col_inner: table|number|nil,\n  alpha: table|number|nil,\n  block: number?,\n  line: table|number|nil,\n  radius: table|number|nil,\n  col_back: number?,\n  alpha_back: number?,\n  back: table|number|nil,\n  rotate: number?,\n  X: number?,\n  Y: number?,\n  antialias: boolean|number|nil,\n}

