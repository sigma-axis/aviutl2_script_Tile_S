root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Lua scripts for AviUtl2
[*.{lua,obj2,anm2,scn2,cam2,tra2}]
indent_style = space
indent_size = 4

# HLSL shaders
[*.hlsl]
indent_style = space
indent_size = 4

# YAML configuration
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
